<!-- AVLS (variable valve lift) switchover — RomRaider def fragment for D2WD610H
     Reverse-engineered from avls_cam_mode_state_machine @ 0x40168.
     Switchover is a load-vs-RPM line (two operating-state-selected 7-point float curves)
     plus a hard RPM hysteresis pair (4000 engage / 3800 release).
     Curve 1 is selected when 0xFFFFCD9C == 2; curve 2 when it == 3. Each curve uses its
     own +10 engage hysteresis and raw curve for release. Normal compared load = 0xFFFFB46C.
     All values are IEEE754 float32, big-endian, real units (no scaling needed). -->

<table name="AVLS Switchover Load Threshold 1" category="AVLS" type="2D"
       storagetype="float" endian="big" sizey="7" userlevel="3"
       storageaddress="0x7D67C">
  <scaling units="load (matches value at 0xFFFFB46C)" expression="x" to_byte="x" format="#0.0" fineincrement="1" coarseincrement="10"/>
  <table type="Y Axis" storageaddress="0x7D660" storagetype="float" endian="big">
    <scaling units="RPM" expression="x" to_byte="x" format="#"/>
  </table>
</table>

<table name="AVLS Switchover Load Threshold 2" category="AVLS" type="2D"
       storagetype="float" endian="big" sizey="7" userlevel="3"
       storageaddress="0x7D6B4">
  <scaling units="load" expression="x" to_byte="x" format="#0.0" fineincrement="1" coarseincrement="10"/>
  <table type="Y Axis" storageaddress="0x7D698" storagetype="float" endian="big">
    <scaling units="RPM" expression="x" to_byte="x" format="#"/>
  </table>
</table>

<table name="AVLS High Cam Engage RPM" category="AVLS" type="1D"
       storagetype="float" endian="big" sizey="1" userlevel="3"
       storageaddress="0x7D4BC">
  <scaling units="RPM" expression="x" to_byte="x" format="#"/>
</table>

<table name="AVLS High Cam Release RPM" category="AVLS" type="1D"
       storagetype="float" endian="big" sizey="1" userlevel="3"
       storageaddress="0x7D4B8">
  <scaling units="RPM" expression="x" to_byte="x" format="#"/>
</table>

<table name="AVLS Threshold Hysteresis Offset A" category="AVLS" type="1D"
       storagetype="float" endian="big" sizey="1" userlevel="4"
       storageaddress="0x7D480">
  <scaling units="load" expression="x" to_byte="x" format="#0.0"/>
</table>

<table name="AVLS Threshold Hysteresis Offset B" category="AVLS" type="1D"
       storagetype="float" endian="big" sizey="1" userlevel="4"
       storageaddress="0x7D484">
  <scaling units="load" expression="x" to_byte="x" format="#0.0"/>
</table>

<table name="AVLS Actuation RPM Gate" category="AVLS" type="1D"
       storagetype="float" endian="big" sizey="1" userlevel="4"
       storageaddress="0x7D4AC">
  <scaling units="RPM" expression="x" to_byte="x" format="#"/>
</table>

